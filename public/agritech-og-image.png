<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" fill="none">
  <!-- Background gradient -->
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#1a1a1a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0a0a0a;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#22c55e;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#22c55e;stop-opacity:0" />
    </radialGradient>
  </defs>
  
  <rect width="1200" height="630" fill="url(#bg)"/>
  <circle cx="600" cy="315" r="400" fill="url(#glow)"/>
  
  <!-- Grid pattern -->
  <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
    <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#22c55e" stroke-width="1" opacity="0.1"/>
  </pattern>
  <rect width="1200" height="630" fill="url(#grid)"/>
  
  <!-- Leaf icon -->
  <g transform="translate(500, 200)">
    <path d="M50 10 Q25 25, 20 60 Q25 95, 50 110 Q75 95, 80 60 Q75 25, 50 10 Z" 
          fill="#22c55e" 
          stroke="#84cc16" 
          stroke-width="3"/>
    <path d="M50 10 L50 110" 
          stroke="#16a34a" 
          stroke-width="3" 
          stroke-linecap="round"/>
  </g>
  
  <!-- Text -->
  <text x="600" y="380" font-family="system-ui, -apple-system, sans-serif" font-size="72" font-weight="bold" fill="#ffffff" text-anchor="middle">
    AgriTech <tspan fill="#84cc16">3.0</tspan>
  </text>
  
  <text x="600" y="440" font-family="system-ui, -apple-system, sans-serif" font-size="32" fill="#a3a3a3" text-anchor="middle">
    Agriculture Innovation Hackathon
  </text>
  
  <text x="600" y="490" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="600" fill="#22c55e" text-anchor="middle">
    March 16-17, 2026
  </text>
</svg>